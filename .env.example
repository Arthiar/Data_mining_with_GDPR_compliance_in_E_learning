# Configuration template.
# Copy this file to ".env" and fill in your own values.
# Never commit the real ".env" file.

# Base URL of your Moodle instance, without a trailing slash.
MOODLE_BASE_URL=https://your-moodle-instance.example.com

# Moodle Web Services token.
MOODLE_WSTOKEN=your_web_service_token_here

# Numeric Moodle course ID to analyse.
COURSE_ID=1234

# Comma-separated course-module IDs for each activity type.
# Leave blank if the activity type is not used.
QUIZ_CMIDS=111,222,333
ASSIGN_CMIDS=444,555,666
FORUM_CMIDS=
HVP_CMIDS=777,888
DATA_CMIDS=999

# Secret salt used for deterministic SHA-256 pseudonymisation of user IDs.
# Use a long private random string. Changing it changes all anon_user values.
HASH_SALT=replace_with_a_long_random_secret_string
