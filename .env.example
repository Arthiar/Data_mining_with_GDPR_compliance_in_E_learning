# ─────────────────────────────────────────────────────────────
#  Configuration template — copy this file to ".env" and fill
#  in your own values.  NEVER commit the real .env file.
# ─────────────────────────────────────────────────────────────

# Base URL of your Moodle instance (no trailing slash)
MOODLE_BASE_URL=https://your-moodle-instance.example.com

# Moodle Web Services token (generate in Site Admin → Plugins → Web Services)
MOODLE_WSTOKEN=your_web_service_token_here

# Numeric Moodle course ID to analyse
COURSE_ID=1234

# Comma-separated course-module IDs for each activity type
# Leave blank if the activity type is not present in your course
QUIZ_CMIDS=111,222,333
ASSIGN_CMIDS=444,555,666
FORUM_CMIDS=
HVP_CMIDS=777,888
DATA_CMIDS=999

# Secret salt used for deterministic SHA-256 pseudonymisation of user IDs.
# Choose any long random string.  Changing it will change all anon_user values.
HASH_SALT=replace_with_a_long_random_secret_string
